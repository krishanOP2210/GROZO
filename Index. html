<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>GROZO</title>
  <link rel="stylesheet" href="styles.css" />
</head>

<body>

<header class="site-header">
  <h1>GROZO ⚡</h1>
  <button id="cartBtn">🛒 <span id="cartCount">0</span></button>
</header>

<main>

  <!-- SEARCH -->
  <input id="searchInput" placeholder="Search groceries..." />

  <!-- CATEGORIES -->
  <div id="categoryGrid" class="category-grid"></div>

  <!-- PRODUCTS -->
  <div id="productsGrid" class="product-grid"></div>

</main>

<!-- ✅ PARTNER SECTION -->
<section class="partner">
  <h2>Become a Grozo Partner 🤝</h2>
  <p>Enter your Gmail and connect with us</p>

  <input type="email" id="partnerEmail" placeholder="Enter your Gmail" />

  <br><br>

  <button onclick="becomePartner()">Become Partner</button>
</section>

<script src="script.js"></script>
</body>
</html>
